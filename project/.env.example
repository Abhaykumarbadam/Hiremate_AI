# HireMate AI Environment Variables Example
# Copy this file to .env and fill in your values

# Supabase Configuration (Not used in current version, but included in template)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini API (required for AI resume analysis, questions, evaluation)
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: used automatically when the primary key hits quota/credit limits
GEMINI_API_KEY_FALLBACK=your-backup-gemini-api-key-here

# Backend API URL (frontend — use your Render URL in production)
# VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://your-service.onrender.com

# CORS — comma-separated frontend URLs allowed to call the API
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Optional: path to ffmpeg.exe (needed for WebM voice answers → WAV for speech recognition)
# Install: winget install Gyan.FFmpeg
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
