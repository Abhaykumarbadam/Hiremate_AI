# HireMate AI Environment Variables Example
# Copy this file to .env and fill in your values

# Supabase Configuration (Not used in current version, but included in template)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API Configuration
# The frontend expects the backend to run on http://localhost:8000
# If you change this, update src/config/api.ts accordingly
# VITE_API_URL=http://localhost:8000
